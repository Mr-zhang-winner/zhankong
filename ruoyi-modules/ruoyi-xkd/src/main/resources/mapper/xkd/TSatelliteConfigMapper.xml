<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.xkd.mapper.TSatelliteConfigMapper">
    
    <resultMap type="TSatelliteConfig" id="TSatelliteConfigResult">
        <result property="satelliteId"    column="satellite_id"    />
        <result property="satelliteCode"    column="satellite_code"    />
        <result property="satelliteName"    column="satellite_name"    />
        <result property="ephemerisType"    column="ephemeris_type"    />
        <result property="orbitParams"    column="orbit_params"    />
        <result property="receiveParams"    column="receive_params"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTSatelliteConfigVo">
        select satellite_id, satellite_code, satellite_name, ephemeris_type, orbit_params, receive_params, status, create_by, create_time, update_by, update_time, remark from t_satellite_config
    </sql>

    <select id="selectTSatelliteConfigList" parameterType="TSatelliteConfig" resultMap="TSatelliteConfigResult">
        <include refid="selectTSatelliteConfigVo"/>
        <where>  
            <if test="satelliteCode != null  and satelliteCode != ''"> and satellite_code = #{satelliteCode}</if>
            <if test="satelliteName != null  and satelliteName != ''"> and satellite_name like concat('%', #{satelliteName}, '%')</if>
            <if test="ephemerisType != null  and ephemerisType != ''"> and ephemeris_type = #{ephemerisType}</if>
            <if test="orbitParams != null  and orbitParams != ''"> and orbit_params = #{orbitParams}</if>
            <if test="receiveParams != null  and receiveParams != ''"> and receive_params = #{receiveParams}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectTSatelliteConfigBySatelliteId" parameterType="Long" resultMap="TSatelliteConfigResult">
        <include refid="selectTSatelliteConfigVo"/>
        where satellite_id = #{satelliteId}
    </select>

    <insert id="insertTSatelliteConfig" parameterType="TSatelliteConfig" useGeneratedKeys="true" keyProperty="satelliteId">
        insert into t_satellite_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="satelliteCode != null and satelliteCode != ''">satellite_code,</if>
            <if test="satelliteName != null and satelliteName != ''">satellite_name,</if>
            <if test="ephemerisType != null and ephemerisType != ''">ephemeris_type,</if>
            <if test="orbitParams != null">orbit_params,</if>
            <if test="receiveParams != null">receive_params,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="satelliteCode != null and satelliteCode != ''">#{satelliteCode},</if>
            <if test="satelliteName != null and satelliteName != ''">#{satelliteName},</if>
            <if test="ephemerisType != null and ephemerisType != ''">#{ephemerisType},</if>
            <if test="orbitParams != null">#{orbitParams},</if>
            <if test="receiveParams != null">#{receiveParams},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateTSatelliteConfig" parameterType="TSatelliteConfig">
        update t_satellite_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="satelliteCode != null and satelliteCode != ''">satellite_code = #{satelliteCode},</if>
            <if test="satelliteName != null and satelliteName != ''">satellite_name = #{satelliteName},</if>
            <if test="ephemerisType != null and ephemerisType != ''">ephemeris_type = #{ephemerisType},</if>
            <if test="orbitParams != null">orbit_params = #{orbitParams},</if>
            <if test="receiveParams != null">receive_params = #{receiveParams},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where satellite_id = #{satelliteId}
    </update>

    <delete id="deleteTSatelliteConfigBySatelliteId" parameterType="Long">
        delete from t_satellite_config where satellite_id = #{satelliteId}
    </delete>

    <delete id="deleteTSatelliteConfigBySatelliteIds" parameterType="String">
        delete from t_satellite_config where satellite_id in 
        <foreach item="satelliteId" collection="array" open="(" separator="," close=")">
            #{satelliteId}
        </foreach>
    </delete>
</mapper>