<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.xkd.mapper.TSystemParamMapper">
    
    <resultMap type="TSystemParam" id="TSystemParamResult">
        <result property="paramId"    column="param_id"    />
        <result property="paramCode"    column="param_code"    />
        <result property="paramName"    column="param_name"    />
        <result property="paramValue"    column="param_value"    />
        <result property="paramType"    column="param_type"    />
        <result property="paramDesc"    column="param_desc"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTSystemParamVo">
        select param_id, param_code, param_name, param_value, param_type, param_desc, status, create_by, create_time, update_by, update_time, remark from t_system_param
    </sql>

    <select id="selectTSystemParamList" parameterType="TSystemParam" resultMap="TSystemParamResult">
        <include refid="selectTSystemParamVo"/>
        <where>  
            <if test="paramCode != null  and paramCode != ''"> and param_code = #{paramCode}</if>
            <if test="paramName != null  and paramName != ''"> and param_name like concat('%', #{paramName}, '%')</if>
            <if test="paramValue != null  and paramValue != ''"> and param_value = #{paramValue}</if>
            <if test="paramType != null  and paramType != ''"> and param_type = #{paramType}</if>
            <if test="paramDesc != null  and paramDesc != ''"> and param_desc = #{paramDesc}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectTSystemParamByParamId" parameterType="Long" resultMap="TSystemParamResult">
        <include refid="selectTSystemParamVo"/>
        where param_id = #{paramId}
    </select>

    <insert id="insertTSystemParam" parameterType="TSystemParam" useGeneratedKeys="true" keyProperty="paramId">
        insert into t_system_param
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="paramCode != null and paramCode != ''">param_code,</if>
            <if test="paramName != null and paramName != ''">param_name,</if>
            <if test="paramValue != null and paramValue != ''">param_value,</if>
            <if test="paramType != null and paramType != ''">param_type,</if>
            <if test="paramDesc != null">param_desc,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="paramCode != null and paramCode != ''">#{paramCode},</if>
            <if test="paramName != null and paramName != ''">#{paramName},</if>
            <if test="paramValue != null and paramValue != ''">#{paramValue},</if>
            <if test="paramType != null and paramType != ''">#{paramType},</if>
            <if test="paramDesc != null">#{paramDesc},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateTSystemParam" parameterType="TSystemParam">
        update t_system_param
        <trim prefix="SET" suffixOverrides=",">
            <if test="paramCode != null and paramCode != ''">param_code = #{paramCode},</if>
            <if test="paramName != null and paramName != ''">param_name = #{paramName},</if>
            <if test="paramValue != null and paramValue != ''">param_value = #{paramValue},</if>
            <if test="paramType != null and paramType != ''">param_type = #{paramType},</if>
            <if test="paramDesc != null">param_desc = #{paramDesc},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where param_id = #{paramId}
    </update>

    <delete id="deleteTSystemParamByParamId" parameterType="Long">
        delete from t_system_param where param_id = #{paramId}
    </delete>

    <delete id="deleteTSystemParamByParamIds" parameterType="String">
        delete from t_system_param where param_id in 
        <foreach item="paramId" collection="array" open="(" separator="," close=")">
            #{paramId}
        </foreach>
    </delete>
</mapper>